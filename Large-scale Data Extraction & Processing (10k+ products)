# 3. KONTROLIERIS
# ==========================================
def process_single_sku(sku, data):
    name = data['name']
    
    product_folder = os.path.join(OUTPUT_BASE_DIR, sku)
    os.makedirs(product_folder, exist_ok=True)
    apraksts_path = os.path.join(product_folder, 'apraksts.txt')
    archive_link = f"/wp-content/SISO_archive/{sku}/index.php"

    print(f"\n> Apstrādājam: {sku}")
    urls_to_download = set() 
    web_desc = "Apraksts nav atrasts"
    categories = []
    
    found_url = get_product_url(sku)
    
    if found_url:
        print(f"  [LAPA] Atrasta: {found_url}")
        urls_to_download, web_desc, categories = extract_gallery_from_product_page(found_url)
    else:
        print("  [X] Produkta lapa netika atrasta Siso sistēmā.")

    downloaded_count = 0
    pdf_count = 0

    if urls_to_download:
        for opt_url, fallback_url, fname, orig_ext in urls_to_download:
            save_path = os.path.join(product_folder, fname)
            fallback_path = os.path.join(product_folder, fname.replace('.webp', orig_ext))
            
            if os.path.exists(save_path) or os.path.exists(fallback_path):
                if '.pdf' in fname.lower(): pdf_count += 1
                else: downloaded_count += 1
                continue
                
            time.sleep(random.uniform(0.3, 0.5))
            success, final_name = download_file_with_fallback(opt_url, fallback_url, product_folder, fname, orig_ext)
            if success:
                print(f"    [+] Saglabāts: {final_name}")
                if '.pdf' in final_name.lower(): pdf_count += 1
                else: downloaded_count += 1

    create_product_gallery(product_folder, sku, name)
    
    with open(apraksts_path, 'w', encoding='utf-8') as f:
        f.write(f"SKU: {sku}\nNosaukums: {name}\n\nWeb Apraksts:\n{web_desc}")
        
    cat_string = " > ".join(categories) if categories else "Standarta katalogs"
    
    json_data = {
        "sku": sku,
        "name": name,
        "category": cat_string,
        "archive_link": archive_link,
        "type": data['type'],
        "weight": "0.00", 
        "price": "0.00"
    }
    
    report_data = {
        "Kods": sku,
        "Nosaukums": name,
        "Kategorija": cat_string,
        "Lapas_URL": found_url if found_url else "Nav atrasts",
        "Bildes_skaits": downloaded_count,
        "PDF_skaits": pdf_count
    }
    
    return json_data, report_data

def main():
    print("=== SĀKAM LOKĀLO DATU BĀZES BŪVĒŠANU ===")
    os.makedirs(OUTPUT_BASE_DIR, exist_ok=True)
    
    products = load_data()
    sku_list = list(products.keys())
    
    if not sku_list:
        print("⚠️ Kļūda: Nav atrasti CSV faili!")
        return
        
    total_found = len(sku_list)
    print(f"Kopā atrasti {total_found} unikāli kodi PIM failā.")

    # ==========================================
    # PORCIJU (BATCHING) KONTROLE (Pa 3000 vai cik vajag)
    # ==========================================
    START_INDEX = 5500
    END_INDEX = 7000  # Šobrīd uzlikts no 1000 līdz 4000
    
    sku_list_batch = sku_list[START_INDEX:END_INDEX]
    total_skus = len(sku_list_batch)
    
    print(f"⬇️ Apstrādāsim porciju no indeksa {START_INDEX} līdz {END_INDEX} (Kopā: {total_skus} gab.)")
    
    frontend_data = []
    report_data_list = []
    
    processed_count = 0
    found_urls_count = 0
    
    for sku in sku_list_batch:
        j_data, r_data = process_single_sku(sku, products[sku])
        frontend_data.append(j_data)
        report_data_list.append(r_data)
        
        processed_count += 1
        if r_data["Lapas_URL"] != "Nav atrasts":
            found_urls_count += 1
            
        if processed_count % 20 == 0 or processed_count == total_skus:
            # 💥 JAUNIE APRĒĶINI 💥
            overall_percent = (processed_count / total_skus) * 100
            found_percent = (found_urls_count / processed_count) * 100 if processed_count > 0 else 0
            
            print(f"\n" + "="*55)
            print(f" 📊 KOPĒJAIS PROGRESS: {processed_count} / {total_skus} apstrādāti ({overall_percent:.1f}%)")
            print(f" 🔗 ATRASTAS LAPAS: {found_urls_count} no {processed_count} ({found_percent:.1f}% panākumi)")
            print("="*55 + "\n")

    batch_suffix = f"_{START_INDEX}_{END_INDEX}"
    batch_json = JSON_OUTPUT.replace(".json", f"{batch_suffix}.json")
    batch_csv = REPORT_CSV.replace(".csv", f"{batch_suffix}.csv")

    if frontend_data:
        with open(batch_json, 'w', encoding='utf-8') as f:
            json.dump(frontend_data, f, ensure_ascii=False, indent=4)
        print(f"\n[OK] Porcijas JSON sagenerēts: {batch_json}")

    if report_data_list:
        df_report = pd.DataFrame(report_data_list)
        df_report.to_csv(batch_csv, index=False, encoding='utf-8-sig', sep=';')
        print(f"[OK] Porcijas CSV Atskaite sagenerēta: {batch_csv}")

    main_php_path = os.path.join(OUTPUT_BASE_DIR, "index.php")
    main_php_content = """<?php
define('WP_USE_THEMES', false);
ini_set('display_errors', 0);
?>
<!DOCTYPE html><html lang="lv"><head><meta charset="UTF-8"><title>SISO Arhīvs</title>
<style>
    body { font-family: sans-serif; background: #f0f0f1; padding: 20px; }
    .container { max-width: 1000px; margin: auto; background: #fff; padding: 20px; border-radius: 5px; }
    a { display: inline-block; padding: 5px 10px; margin: 5px; background: #e0e0e0; text-decoration: none; color: #333; border-radius: 3px; }
    a:hover { background: #2271b1; color: #fff; }
</style></head><body>
<div class="container">
    <h2>SISO Produktu Arhīvs</h2><hr>
    <div>
        <?php
        $dirs = array_filter(glob('*'), 'is_dir');
        foreach($dirs as $dir) {
            echo "<a href='" . htmlspecialchars($dir) . "/index.php'>" . htmlspecialchars($dir) . "</a>";
        }
        ?>
    </div>
</div></body></html>"""
    
    with open(main_php_path, 'w', encoding='utf-8') as f:
        f.write(main_php_content)
    print("=== BATCH PABEIGTS! ===")

if __name__ == "__main__":
    main()
