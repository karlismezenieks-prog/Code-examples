# ==========================================
# 1. DATU IELĀDE (Tikai Lielais SISO fails)
# ==========================================
def load_data():
    products = {}
    try:
        if os.path.exists(SISO_CSV):
            df_siso = pd.read_csv(SISO_CSV, sep=';', dtype=str, encoding='utf-8')
            for _, row in df_siso.iterrows():
                sku = str(row.get('Produkta Nr.', '')).strip()
                siso_name = str(row.get('Apraksts', '')).strip()
                
                if not sku or sku == 'nan': continue
                if not siso_name or siso_name == 'nan': siso_name = "Nezināms"

                products[sku] = {'name': siso_name, 'type': 'standarta_katalogs'}
                
    except Exception as e: 
        print(f"Kļūda ielasot SISO CSV: {e}")

    return products

# ==========================================
# 2. WEB SCRAPING FUNKCIJAS
# ==========================================
def get_product_url(sku):
    base_sku = sku.rsplit('-', 1)[0] if '-' in sku else sku
    
    search_urls = [
        f"https://siso.dk/products?q={urllib.parse.quote(sku)}",
        f"https://siso.dk/products?q={urllib.parse.quote(base_sku)}"
    ]
    
    for url in search_urls:
        try:
            time.sleep(random.uniform(0.3, 0.5)) 
            r = session.get(url, timeout=15)
            if r.status_code == 404: continue
            r.raise_for_status()
            
            if '?q=' not in r.url.lower() and '/products/' in r.url.lower():
                if len(r.url.split('/')) >= 5: 
                    return r.url
                    
            soup = BeautifulSoup(r.text, 'html.parser')
            article = soup.find('article', attrs={"data-product-id": sku})
            if not article:
                article = soup.find('article', attrs={"data-product-id": base_sku})
            
            if article:
                link = article.find('a', href=True)
                if link:
                    return urllib.parse.urljoin("https://siso.dk", link['href'])
                    
        except requests.exceptions.RequestException:
            continue
            
    return None

def extract_gallery_from_product_page(product_url):
    found_files = set()
    web_desc = "Apraksts nav atrasts"
    categories = []
    
    try:
        time.sleep(random.uniform(0.3, 0.5))
        r = session.get(product_url, timeout=15)
        soup = BeautifulSoup(r.text, 'html.parser')
        
        desc_elem = soup.find(attrs={"itemprop": "description"})
        if desc_elem and desc_elem.find('h1'):
            web_desc = desc_elem.find('h1').get_text(strip=True)

        for item in soup.find_all('li', class_=lambda c: c and 'breadcrumb' in c):
            txt = item.get_text(strip=True)
            if txt: categories.append(txt)

        media_urls = set()
        for a in soup.find_all('a', href=True): media_urls.add(a['href'])
        for img in soup.find_all('img'):
            if img.get('src'): media_urls.add(img['src'])
            if img.get('data-src'): media_urls.add(img['data-src'])

        for url in media_urls:
            clean_url = urllib.parse.unquote(url.split('?')[0]) 
            if '/files/images/ecom/products/' in clean_url.lower():
                if clean_url.lower().endswith(('.jpg', '.jpeg', '.png', '.webp')):
                    opt_url = f"{ASHX_BASE}{urllib.parse.quote(clean_url, safe='')}&width=1920&format=webp"
                    fallback_url = urllib.parse.urljoin("https://siso.dk", clean_url)
                    orig_ext = '.' + clean_url.rsplit('.', 1)[-1]
                    fname = os.path.basename(clean_url).rsplit('.', 1)[0] + ".webp"
                    if 'drawings' in clean_url.lower(): fname = f"DRAWING_{fname}"
                    found_files.add((opt_url, fallback_url, fname, orig_ext))
                elif clean_url.lower().endswith('.pdf'):
                    bad_keywords = ['code of conduct', 'iso_', 'terms', 'betingelser', 'fejlfinding', 'vejledning', 'montagevejledning', 'hã¦ngsel', 'hængsel', 'dansk']
                    if any(bad in clean_url.lower() for bad in bad_keywords): continue 
                    d_url = urllib.parse.urljoin(product_url, url)
                    fname = urllib.parse.unquote(os.path.basename(clean_url))
                    found_files.add((d_url, d_url, fname, '.pdf'))

    except Exception as e:
        print(f"  [KĻŪDA parsējot lapu]: {e}")
        
    return found_files, web_desc, categories

def download_file_with_fallback(opt_url, fallback_url, save_folder, fname, orig_ext):
    save_path = os.path.join(save_folder, fname)
    if os.path.exists(save_path): return True, fname
    try:
        r = session.get(opt_url, stream=True, timeout=10)
        if r.status_code == 200 and len(r.content) > 1000:
            with open(save_path, 'wb') as f: f.write(r.content)
            return True, fname
    except: pass
    
    if fallback_url and fallback_url != opt_url:
        fallback_name = fname.replace('.webp', orig_ext)
        fallback_path = os.path.join(save_folder, fallback_name)
        if os.path.exists(fallback_path): return True, fallback_name
        try:
            r = session.get(fallback_url, stream=True, timeout=10)
            if r.status_code == 200 and len(r.content) > 1000:
                with open(fallback_path, 'wb') as f: f.write(r.content)
                return True, fallback_name
        except: pass
    return False, fname

