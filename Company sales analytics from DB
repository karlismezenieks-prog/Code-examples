<script>
    // [DOM MANIPULĀCIJA UN CUSTOM SORTING]
    
    // GUDRAIS JAVASCRIPT KĀRTOŠANAS (SORTING) SKRIPTS VISĀM TABULĀM
    // Šis skripts apstrādā gan plakanās (flat) tabulas, gan sarežģītās Tree-View tabulas
    document.querySelectorAll('th.sortable').forEach(th => {
        th.addEventListener('click', function() {
            const table = th.closest('table');
            const tbody = table.querySelector('tbody');
            const colIndex = Array.from(th.parentNode.children).indexOf(th);
            
            let currentOrder = th.getAttribute('data-order');
            let order = (currentOrder === 'desc') ? 'asc' : 'desc';
            
            table.querySelectorAll('th').forEach(h => h.removeAttribute('data-order'));
            th.setAttribute('data-order', order);

            const isTree = table.classList.contains('tree-table');

            // Datu normalizācija kārtošanai (izņemot UI simbolus un formatējot datumus/valūtu)
            const parseValue = (val) => {
                val = val.replace(/📄|📅/g, '').trim();
                if (val === '-' || val === '') return -Infinity; 
                
                let dateMatch = val.match(/^(\d{2})\.(\d{2})\.(\d{2,4})/);
                if (dateMatch) {
                    let y = parseInt(dateMatch[3]);
                    if (y < 100) y += 2000;
                    return new Date(y, parseInt(dateMatch[2])-1, parseInt(dateMatch[1])).getTime();
                }
                
                let numVal = val.replace(/\s/g, '').replace('€', '').replace('%', '').trim();
                if (numVal !== '' && !isNaN(parseFloat(numVal)) && isFinite(numVal)) {
                    return parseFloat(numVal);
                }
                return val.toLowerCase();
            };

            if (isTree) {
                // Kārto vecāku (Parent) mezglus
                let rows = Array.from(tbody.querySelectorAll('tr.tree-parent'));
                rows.sort((a, b) => {
                    let v1 = parseValue(a.children[colIndex].textContent);
                    let v2 = parseValue(b.children[colIndex].textContent);
                    if (v1 < v2) return order === 'asc' ? -1 : 1;
                    if (v1 > v2) return order === 'asc' ? 1 : -1;
                    return 0;
                });
                
                // Kārto bērnu (Child) mezglus ietvaros katram vecākam, saglabājot hierarhiju
                rows.forEach(parentRow => {
                    tbody.appendChild(parentRow); 
                    let groupId = parentRow.getAttribute('data-group');
                    let children = Array.from(tbody.querySelectorAll('.child-' + groupId));
                    
                    children.sort((a, b) => {
                        let v1 = parseValue(a.children[colIndex].textContent);
                        let v2 = parseValue(b.children[colIndex].textContent);
                        if (v1 < v2) return order === 'asc' ? -1 : 1;
                        if (v1 > v2) return order === 'asc' ? 1 : -1;
                        return 0;
                    });
                    
                    children.forEach(child => tbody.appendChild(child)); 
                });
            } else {
                // Standarta tabulu kārtošana
                let rows = Array.from(tbody.querySelectorAll('tr:not(.total-row)'));
                rows.sort((a, b) => {
                    let v1 = parseValue(a.children[colIndex].textContent);
                    let v2 = parseValue(b.children[colIndex].textContent);
                    if (v1 < v2) return order === 'asc' ? -1 : 1;
                    if (v1 > v2) return order === 'asc' ? 1 : -1;
                    return 0;
                });
                rows.forEach(row => tbody.appendChild(row));
            }
        });
    });
</script>
